{
  "framework": "astro",
  "buildCommand": "astro build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": ".*\\.(com|it|pl)$"
        }
      ],
      "destination": "/en",
      "permanent": false,
      "missing": [
        {
          "type": "cookie",
          "key": "pref-lang",
          "value": "ro"
        }
      ]
    },
    {
      "source": "/contact",
      "has": [
        {
          "type": "host",
          "value": ".*\\.(com|it|pl)$"
        }
      ],
      "destination": "/en/contact",
      "permanent": false,
      "missing": [
        {
          "type": "cookie",
          "key": "pref-lang",
          "value": "ro"
        }
      ]
    },
    {
      "source": "/cum-functioneaza",
      "has": [
        {
          "type": "host",
          "value": ".*\\.(com|it|pl)$"
        }
      ],
      "destination": "/en/cum-functioneaza",
      "permanent": false,
      "missing": [
        {
          "type": "cookie",
          "key": "pref-lang",
          "value": "ro"
        }
      ]
    },
    {
      "source": "/termeni",
      "has": [
        {
          "type": "host",
          "value": ".*\\.(com|it|pl)$"
        }
      ],
      "destination": "/en/termeni",
      "permanent": false,
      "missing": [
        {
          "type": "cookie",
          "key": "pref-lang",
          "value": "ro"
        }
      ]
    },
    {
      "source": "/confidentialitate",
      "has": [
        {
          "type": "host",
          "value": ".*\\.(com|it|pl)$"
        }
      ],
      "destination": "/en/confidentialitate",
      "permanent": false,
      "missing": [
        {
          "type": "cookie",
          "key": "pref-lang",
          "value": "ro"
        }
      ]
    },
    {
      "source": "/gdpr",
      "has": [
        {
          "type": "host",
          "value": ".*\\.(com|it|pl)$"
        }
      ],
      "destination": "/en/gdpr",
      "permanent": false,
      "missing": [
        {
          "type": "cookie",
          "key": "pref-lang",
          "value": "ro"
        }
      ]
    },
    {
      "source": "/cookies",
      "has": [
        {
          "type": "host",
          "value": ".*\\.(com|it|pl)$"
        }
      ],
      "destination": "/en/cookies",
      "permanent": false,
      "missing": [
        {
          "type": "cookie",
          "key": "pref-lang",
          "value": "ro"
        }
      ]
    },
    {
      "source": "/produse",
      "has": [
        {
          "type": "host",
          "value": ".*\\.(com|it|pl)$"
        }
      ],
      "destination": "/en/produse",
      "permanent": false,
      "missing": [
        {
          "type": "cookie",
          "key": "pref-lang",
          "value": "ro"
        }
      ]
    },
    {
      "source": "/produse/:slug",
      "has": [
        {
          "type": "host",
          "value": ".*\\.(com|it|pl)$"
        }
      ],
      "destination": "/en/produse/:slug",
      "permanent": false,
      "missing": [
        {
          "type": "cookie",
          "key": "pref-lang",
          "value": "ro"
        }
      ]
    },
    {
      "source": "/privacy",
      "destination": "/confidentialitate",
      "permanent": true
    },
    {
      "source": "/privacy.html",
      "destination": "/confidentialitate",
      "permanent": true
    },
    {
      "source": "/terms",
      "destination": "/termeni",
      "permanent": true
    },
    {
      "source": "/terms.html",
      "destination": "/termeni",
      "permanent": true
    },
    {
      "source": "/tos",
      "destination": "/termeni",
      "permanent": true
    },
    {
      "source": "/data-deletion",
      "destination": "/gdpr",
      "permanent": true
    },
    {
      "source": "/products",
      "destination": "/produse",
      "permanent": true
    },
    {
      "source": "/catalog",
      "destination": "/produse",
      "permanent": true
    },
    {
      "source": "/shop",
      "destination": "/produse",
      "permanent": true
    },
    {
      "source": "/shop/:path*",
      "destination": "/produse",
      "permanent": true
    },
    {
      "source": "/product-category/:path*",
      "destination": "/produse",
      "permanent": true
    },
    {
      "source": "/product/:path*",
      "destination": "/produse",
      "permanent": true
    },
    {
      "source": "/produs/:path*",
      "destination": "/produse",
      "permanent": true
    },
    {
      "source": "/cereale-pseudocereale",
      "destination": "/produse/cereale-pseudocereale-vrac",
      "permanent": true
    },
    {
      "source": "/cereale-pseudocereale/:path*",
      "destination": "/produse/cereale-pseudocereale-vrac",
      "permanent": true
    },
    {
      "source": "/fructe",
      "destination": "/produse/fructe",
      "permanent": true
    },
    {
      "source": "/fructe/:path*",
      "destination": "/produse/fructe",
      "permanent": true
    },
    {
      "source": "/condimente",
      "destination": "/produse/condimente-ierburi-arome-vrac",
      "permanent": true
    },
    {
      "source": "/condimente/:path*",
      "destination": "/produse/condimente-ierburi-arome-vrac",
      "permanent": true
    },
    {
      "source": "/suplimente-alimentare",
      "destination": "/produse/suplimente-functionale",
      "permanent": true
    },
    {
      "source": "/suplimente-alimentare/:path*",
      "destination": "/produse/suplimente-functionale",
      "permanent": true
    },
    {
      "source": "/blog",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/blog/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/cart",
      "destination": "/produse",
      "permanent": true
    },
    {
      "source": "/cos",
      "destination": "/produse",
      "permanent": true
    },
    {
      "source": "/checkout",
      "destination": "/produse",
      "permanent": true
    },
    {
      "source": "/finalizare-comanda",
      "destination": "/produse",
      "permanent": true
    },
    {
      "source": "/my-account",
      "destination": "/produse",
      "permanent": true
    },
    {
      "source": "/contul-meu",
      "destination": "/produse",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
