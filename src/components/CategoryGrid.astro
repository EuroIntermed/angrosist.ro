---
/**
 * CategoryGrid — the /produse overview. A responsive grid of the 13 top-level (L1)
 * category tiles, each with its showcase hero image, name and product count,
 * linking to its L1 page (/produse/[l1]). Fully server-rendered at build time from
 * the bundled catalog (SEO + no-JS); images degrade to a themed placeholder.
 */
import type { Locale } from '../i18n/ui'
import { t, localizePath } from '../i18n/utils'
import { categoryName } from '../lib/categories'
import type { CategoryWithCount } from '../lib/catalog-data'
import BaseLayout from './BaseLayout.astro'
import CategoryTiles from './CategoryTiles.astro'

interface Props {
  locale: Locale
  categories: CategoryWithCount[]
}
const { locale, categories } = Astro.props as Props
const c = t(locale)
const cat = c.catalog
const total = categories.reduce((n, g) => n + g.count, 0)
const produseHref = localizePath('/produse', locale)

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: cat.overviewTitle,
  itemListElement: categories.map((g, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: categoryName(g, locale),
    url: new URL(localizePath(`/produse/${g.slug}`, locale), Astro.site).href,
  })),
}
---

<BaseLayout locale={locale} title={c.meta.produseTitle} description={c.meta.produseDescription} breadcrumb={c.nav.produse}>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListJsonLd)} />
  </Fragment>

  <section class="ag-cats">
    <div class="ei-container">
      <div class="ag-cats__head" data-reveal>
        <p class="ei-eyebrow">{cat.overviewEyebrow}</p>
        <h1>{cat.overviewTitle}</h1>
        <p class="ei-lead">{cat.overviewLead}</p>
        <p class="ag-cats__meta"><strong>{categories.length}</strong> {cat.categoriesWord} · <strong>{total}</strong> {cat.results}</p>
      </div>

      <CategoryTiles locale={locale} categories={categories} basePath={produseHref} />
    </div>
  </section>
</BaseLayout>

<style>
  .ag-cats {
    padding-block: clamp(2.5rem, 2rem + 4vw, 5rem);
  }
  .ag-cats__head {
    max-width: 64ch;
    margin-bottom: 2.4rem;
  }
  .ag-cats__head h1 {
    margin-top: 0.7rem;
  }
  .ag-cats__head .ei-lead {
    margin-top: 1rem;
  }
  .ag-cats__meta {
    margin-top: 1.1rem;
    color: var(--ei-faint);
    font-size: 0.92rem;
    font-variant-numeric: tabular-nums;
  }
  .ag-cats__meta strong {
    color: var(--ei-accent-strong);
  }
</style>
