---
/**
 * CategoryGrid — the /produse overview. A responsive grid of category tiles, each
 * with the category's showcase hero image, name and (live) product count, linking
 * to its own page (/produse/[slug]). Fully server-rendered at build time from the
 * joined catalog data (SEO + no-JS); images degrade to a themed placeholder.
 */
import type { Locale } from '../i18n/ui'
import { t, localizePath } from '../i18n/utils'
import { categoryName } from '../lib/categories'
import type { CategoryWithProducts } from '../lib/catalog-data'
import BaseLayout from './BaseLayout.astro'

interface Props {
  locale: Locale
  categories: CategoryWithProducts[]
}
const { locale, categories } = Astro.props as Props
const c = t(locale)
const cat = c.catalog
const total = categories.reduce((n, g) => n + g.count, 0)

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: cat.overviewTitle,
  itemListElement: categories.map((g, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: categoryName(g, locale),
    url: new URL(localizePath(`/produse/${g.slug}`, locale), Astro.site).href,
  })),
}
---

<BaseLayout locale={locale} title={c.meta.produseTitle} description={c.meta.produseDescription} breadcrumb={c.nav.produse}>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListJsonLd)} />
  </Fragment>

  <section class="ag-cats">
    <div class="ei-container">
      <div class="ag-cats__head" data-reveal>
        <p class="ei-eyebrow">{cat.overviewEyebrow}</p>
        <h1>{cat.overviewTitle}</h1>
        <p class="ei-lead">{cat.overviewLead}</p>
        <p class="ag-cats__meta"><strong>{categories.length}</strong> {cat.categoriesWord} · <strong>{total}</strong> {cat.results}</p>
      </div>

      <ul class="ag-cats__grid" role="list">
        {
          categories.map((g) => {
            const href = localizePath(`/produse/${g.slug}`, locale)
            const name = categoryName(g, locale)
            const hasImg = /^https?:\/\//i.test(g.imagine)
            return (
              <li class="ag-cat-card">
                <a class="ag-cat-card__link" href={href}>
                  <span class="ag-cat-card__media">
                    {hasImg ? (
                      <img src={g.imagine} alt={name} loading="lazy" decoding="async" width="480" height="320" />
                    ) : (
                      <span class="ag-cat-card__ph" aria-hidden="true">{(name.trim()[0] || '·').toUpperCase()}</span>
                    )}
                    <span class="ag-cat-card__badge">{g.count} {cat.results}</span>
                  </span>
                  <span class="ag-cat-card__body">
                    <span class="ag-cat-card__name">{name}</span>
                    <span class="ag-cat-card__cta">
                      {cat.viewProducts}
                      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
                    </span>
                  </span>
                </a>
              </li>
            )
          })
        }
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .ag-cats {
    padding-block: clamp(2.5rem, 2rem + 4vw, 5rem);
  }
  .ag-cats__head {
    max-width: 64ch;
    margin-bottom: 2.4rem;
  }
  .ag-cats__head h1 {
    margin-top: 0.7rem;
  }
  .ag-cats__head .ei-lead {
    margin-top: 1rem;
  }
  .ag-cats__meta {
    margin-top: 1.1rem;
    color: var(--ei-faint);
    font-size: 0.92rem;
    font-variant-numeric: tabular-nums;
  }
  .ag-cats__meta strong {
    color: var(--ei-accent-strong);
  }

  .ag-cats__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
    gap: 1.4rem;
  }

  .ag-cat-card {
    position: relative;
  }
  .ag-cat-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    border: 1px solid var(--ei-hairline);
    border-radius: var(--ei-radius-lg);
    overflow: hidden;
    background: var(--ei-surface);
    box-shadow: var(--ei-shadow-sm);
    text-decoration: none;
    color: inherit;
    transition: transform 0.22s var(--ei-ease-out), box-shadow 0.25s var(--ei-ease),
      border-color 0.2s var(--ei-ease);
  }
  .ag-cat-card__link:hover {
    transform: translateY(-3px);
    box-shadow: var(--ei-shadow-lg);
    border-color: var(--ei-accent);
  }

  .ag-cat-card__media {
    position: relative;
    display: block;
    aspect-ratio: 3 / 2;
    background: var(--ei-accent-soft);
    overflow: hidden;
  }
  .ag-cat-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s var(--ei-ease-out);
  }
  .ag-cat-card__link:hover .ag-cat-card__media img {
    transform: scale(1.04);
  }
  .ag-cat-card__ph {
    display: grid;
    place-items: center;
    width: 100%;
    height: 100%;
    font-size: 2.6rem;
    font-weight: 800;
    color: var(--ei-accent-text);
    background: var(--ei-accent-soft);
  }
  .ag-cat-card__badge {
    position: absolute;
    top: 0.7rem;
    right: 0.7rem;
    padding: 0.3em 0.7em;
    border-radius: var(--ei-radius-pill);
    background: color-mix(in srgb, var(--ei-surface) 88%, transparent);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    border: 1px solid var(--ei-hairline);
    color: var(--ei-ink-soft);
    font-size: 0.74rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .ag-cat-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 1.05rem 1.2rem 1.2rem;
    flex: 1;
  }
  .ag-cat-card__name {
    font-size: 1.08rem;
    font-weight: 700;
    color: var(--ei-ink);
    line-height: 1.25;
    text-wrap: balance;
  }
  .ag-cat-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: auto;
    color: var(--ei-accent-text);
    font-size: 0.88rem;
    font-weight: 600;
  }
  .ag-cat-card__cta svg {
    transition: transform 0.2s var(--ei-ease-out);
  }
  .ag-cat-card__link:hover .ag-cat-card__cta svg {
    transform: translateX(3px);
  }
</style>
