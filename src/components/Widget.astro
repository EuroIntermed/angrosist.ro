---
/**
 * Widget — the Euro-Intermed AI chat widget embed, configured for Angrosist.
 * The widget is always rendered; only its origin (WIDGET_BASE_URL) comes from
 * env, nothing is hardcoded.
 *
 * The backend API URL is baked into widget.js at build time (frontend's
 * VITE_API_URL) — we deliberately do NOT pass apiUrl here so that single source
 * of truth is preserved. Vertical "angrosist" + intent "buy" put the agent
 * straight into the buyer/sourcing flow.
 *
 * The widget also exposes `window.AngrosistChat.open({ message, vertical, intent })`
 * which the Produse "Comandă" flow calls to launch the chat with a prefilled
 * message (feature-detected in src/scripts/order.ts).
 */
import type { Locale } from '../i18n/ui'
import { widgetBaseUrl } from '../lib/config'
import { localizePath } from '../i18n/utils'
const { locale } = Astro.props as { locale: Locale }
const privacyUrl = localizePath('/confidentialitate', locale)
---

{
  (
    <>
      <script is:inline src={`${widgetBaseUrl}/widget.js`} defer />
      <script
        is:inline
        define:vars={{ lang: locale, privacyUrl, accent: '#0a7290', accentText: '#ffffff' }}
      >
        {`
        // Poll for the deferred widget bundle instead of bailing on a single
        // DOMContentLoaded check: widget.js loads with 'defer', so AngrosistChat
        // may not exist yet when this inline script runs. Retry (up to ~10s) until
        // init is available, then mount the floating launcher exactly once.
        (function () {
          var cfg = {
            vertical: 'angrosist',
            intent: 'buy',
            lang: lang,
            privacyUrl: privacyUrl,
            accent: accent,
            accentText: accentText
          };
          var n = 0;
          (function go() {
            if (window.AngrosistChat && window.AngrosistChat.init) {
              window.AngrosistChat.init(cfg);
              return;
            }
            if (n++ < 200) setTimeout(go, 50);
          })();
        })();
      `}
      </script>
    </>
  )
}
