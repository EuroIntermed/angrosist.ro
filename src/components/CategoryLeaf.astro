---
/**
 * CategoryLeaf — an L2 (subcategory) leaf page: /produse/[l1]/[l2].
 *
 * Renders a back-link to the parent L1, the L2 hero (image + localized name +
 * count + intro) and the product TABLE (search + multi-select + device-aware
 * "Comandă"). SEO: JSON-LD ItemList of the products + a BreadcrumbList
 * Home › Produse › L1 › L2.
 */
import type { Locale } from '../i18n/ui'
import { t, localizePath } from '../i18n/utils'
import { categoryName } from '../lib/categories'
import type { CategoryWithCount, Product } from '../lib/catalog-data'
import BaseLayout from './BaseLayout.astro'
import ProductTable from './ProductTable.astro'

interface Props {
  locale: Locale
  l1: CategoryWithCount
  l2: CategoryWithCount
  products: Product[]
}
const { locale, l1, l2, products } = Astro.props as Props
const c = t(locale)
const cat = c.catalog

const l1Name = categoryName(l1, locale)
const l2Name = categoryName(l2, locale)
const title = cat.categoryMetaTitle.replace('{category}', l2Name)
const description = cat.categoryMetaDescription
  .replace('{category}', l2Name)
  .replace('{count}', String(l2.count))
const intro = cat.categoryIntro.replace('{category}', l2Name)
const l1Href = localizePath(`/produse/${l1.slug}`, locale)

// The order message's "category" is the leaf's Romanian subcategorie (products
// stay Romanian on both locales); fall back to the localized L2 name.
const messageCategory = products[0]?.subcategorie || l2.categorie || l2Name

const abs = (path: string) => new URL(localizePath(path, locale), Astro.site).href
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: c.nav.home, item: abs('/') },
    { '@type': 'ListItem', position: 2, name: c.nav.produse, item: abs('/produse') },
    { '@type': 'ListItem', position: 3, name: l1Name, item: abs(`/produse/${l1.slug}`) },
    { '@type': 'ListItem', position: 4, name: l2Name, item: abs(`/produse/${l1.slug}/${l2.slug}`) },
  ],
}

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: title,
  itemListElement: products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: p.produs,
      category: p.subcategorie,
      description: p.descriere,
    },
  })),
}

const hasHero = /^(https?:\/\/|\/)/i.test(l2.imagine)
---

<BaseLayout locale={locale} title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbJsonLd)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListJsonLd)} />
  </Fragment>

  <section class="ag-catalog">
    <div class="ei-container">
      <a class="ag-cat-back" href={l1Href}>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6" /></svg>
        {l1Name}
      </a>

      <header class="ag-cat-hero" data-reveal>
        <div class="ag-cat-hero__text">
          <p class="ei-eyebrow">{l1Name}</p>
          <h1>{l2Name}</h1>
          <p class="ei-lead">{intro}</p>
          <p class="ag-cat-hero__count"><strong>{l2.count}</strong> {cat.results}</p>
        </div>
        {hasHero && (
          <div class="ag-cat-hero__media">
            <img src={l2.imagine} alt={l2Name} loading="eager" decoding="async" width="640" height="420" onerror="this.closest('.ag-cat-hero__media')?.remove()" />
          </div>
        )}
      </header>

      <ProductTable locale={locale} products={products} leafSlug={l2.slug} categoryLabel={messageCategory} />
    </div>
  </section>
</BaseLayout>

<style>
  .ag-catalog {
    padding-block: clamp(2.5rem, 2rem + 4vw, 5rem);
  }
  .ag-cat-back {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 1.5rem;
    color: var(--ei-muted);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s var(--ei-ease);
  }
  .ag-cat-back:hover {
    color: var(--ei-accent-strong);
  }
  .ag-cat-hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem 2.5rem;
    align-items: center;
    margin-bottom: 2.2rem;
  }
  .ag-cat-hero__text {
    max-width: 60ch;
  }
  .ag-cat-hero__text h1 {
    margin-top: 0.7rem;
  }
  .ag-cat-hero__text .ei-lead {
    margin-top: 0.9rem;
  }
  .ag-cat-hero__count {
    margin-top: 1.1rem;
    color: var(--ei-faint);
    font-size: 0.95rem;
    font-variant-numeric: tabular-nums;
  }
  .ag-cat-hero__count strong {
    color: var(--ei-accent-strong);
    font-size: 1.15rem;
  }
  .ag-cat-hero__media {
    border-radius: var(--ei-radius-lg);
    overflow: hidden;
    border: 1px solid var(--ei-hairline);
    box-shadow: var(--ei-shadow-md);
    aspect-ratio: 16 / 10;
    background: var(--ei-accent-soft);
  }
  .ag-cat-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  @media (min-width: 860px) {
    .ag-cat-hero {
      grid-template-columns: 1.15fr 0.85fr;
    }
  }
</style>
