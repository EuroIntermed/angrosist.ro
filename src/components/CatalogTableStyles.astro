---
/**
 * CatalogTableStyles — the shared, GLOBAL styling for the Angrosist product
 * table, buttons, thumbnails, mobile stacked-card layout and the order chooser
 * sheet. Rendered once on any page that shows the product table (the full
 * catalog and every per-category page) so the runtime-built rows (which carry no
 * Astro scope hash) are styled. All classes are `ag-`-prefixed.
 */
---

<style is:global>
  .ag-catalog {
    padding-block: clamp(2.5rem, 2rem + 4vw, 5rem);
  }
  .ag-catalog__head {
    max-width: 62ch;
    margin-bottom: 2rem;
  }
  .ag-catalog__head h1 {
    margin-top: 0.7rem;
  }
  .ag-catalog__head .ei-lead {
    margin-top: 1rem;
  }
  .ag-catalog__note {
    margin: 0 0 1.5rem;
    padding: 0.7rem 1rem;
    border: 1px dashed var(--ei-gold-strong);
    border-radius: var(--ei-radius-sm);
    background: var(--ei-gold-soft);
    color: var(--ei-ink-soft);
    font-size: 0.86rem;
  }

  /* Toolbar: filter chips + result count */
  .ag-catalog__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1.5rem;
    margin-bottom: 1.4rem;
  }
  .ag-catalog__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }
  .ag-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.5em 1em;
    border: 1px solid var(--ei-hairline-strong);
    border-radius: var(--ei-radius-pill);
    background: var(--ei-surface);
    color: var(--ei-ink-soft);
    font-family: inherit;
    font-size: 0.88rem;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.2s var(--ei-ease), background 0.2s var(--ei-ease), color 0.2s var(--ei-ease), transform 0.15s var(--ei-ease-out);
  }
  .ag-chip:hover {
    border-color: var(--ei-accent);
    transform: translateY(-1px);
  }
  .ag-chip.is-active {
    background: var(--ei-accent-soft);
    border-color: var(--ei-accent);
    color: var(--ei-accent-strong);
    font-weight: 600;
  }
  .ag-catalog__count {
    font-size: 0.84rem;
    font-weight: 600;
    color: var(--ei-faint);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .ag-catalog__count[hidden] {
    display: none;
  }

  /* Status (loading / empty / error) */
  .ag-catalog__status {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    padding: 2.5rem 0;
    color: var(--ei-muted);
  }
  .ag-catalog__status[hidden] {
    display: none;
  }
  .ag-catalog__status.is-loading {
    color: var(--ei-faint);
  }
  .ag-catalog__status.is-error p {
    color: var(--ei-ink-soft);
  }

  /* ---- Self-contained button system (works for SSR + runtime DOM) ----- */
  .ag-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5em;
    padding: 0.6em 1.2em;
    border: 1px solid transparent;
    border-radius: var(--ei-radius-pill);
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.01em;
    cursor: pointer;
    text-align: center;
    transition: transform 0.2s var(--ei-ease-out), box-shadow 0.25s var(--ei-ease),
      background-color 0.2s var(--ei-ease), border-color 0.2s var(--ei-ease), color 0.2s var(--ei-ease);
  }
  .ag-btn:hover {
    transform: translateY(-1px);
    box-shadow: var(--ei-shadow-md);
  }
  .ag-btn:active {
    transform: translateY(0);
  }
  .ag-btn--primary {
    background: var(--ei-accent);
    color: var(--ei-accent-ink);
    box-shadow: var(--ei-shadow-sm);
  }
  .ag-btn--primary:hover {
    background: var(--ei-accent-hover);
    box-shadow: var(--ei-shadow-md);
  }
  .ag-btn--secondary {
    background: transparent;
    color: var(--ei-accent-text);
    border-color: var(--ei-hairline-strong);
  }
  .ag-btn--secondary:hover {
    background: var(--ei-accent-soft);
    border-color: var(--ei-accent);
    color: var(--ei-accent-strong);
  }
  .ag-btn--whatsapp {
    background: var(--ei-whatsapp);
    color: var(--ei-whatsapp-ink);
  }
  .ag-btn--whatsapp:hover {
    filter: brightness(0.96);
  }
  .ag-row__order {
    padding: 0.55em 1.15em;
    font-size: 0.85rem;
    white-space: nowrap;
  }

  /* ---- Table ---------------------------------------------------------- */
  .ag-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--ei-hairline);
    border-radius: var(--ei-radius-lg);
    background: var(--ei-surface);
    box-shadow: var(--ei-shadow-sm);
    -webkit-overflow-scrolling: touch;
  }
  .ag-table-wrap[hidden] {
    display: none;
  }
  .ag-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.94rem;
    min-width: 760px;
  }
  .ag-th {
    text-align: left;
    padding: 0.85rem 1.1rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--ei-faint);
    background: var(--ei-surface-raised);
    border-bottom: 1px solid var(--ei-hairline-strong);
    white-space: nowrap;
  }
  .ag-th--img {
    width: 64px;
  }
  .ag-th--desc {
    width: 38%;
  }
  .ag-th--price {
    text-align: right;
  }
  .ag-th--order {
    width: 1%;
  }

  .ag-row {
    border-bottom: 1px solid var(--ei-hairline);
    transition: background 0.15s var(--ei-ease);
  }
  .ag-row:last-child {
    border-bottom: 0;
  }
  .ag-row:hover {
    background: var(--ei-accent-soft);
  }
  .ag-row[hidden] {
    display: none;
  }
  .ag-td {
    height: 64px;
    padding: 0.7rem 1.1rem;
    vertical-align: middle;
    color: var(--ei-ink-soft);
  }
  .ag-td--img {
    width: 64px;
  }
  .ag-row__name {
    display: block;
    font-weight: 600;
    color: var(--ei-ink);
  }
  .ag-row__name:focus-visible {
    outline: 2px solid var(--ei-accent);
    outline-offset: 2px;
    border-radius: var(--ei-radius-xs);
  }
  /* Compact SKU subtitle under the product name. */
  .ag-row__sku {
    display: block;
    margin-top: 0.15rem;
    font-family: var(--ei-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--ei-faint);
  }
  /* The whole row is a tap target for the product detail modal. */
  .ag-row.is-clickable {
    cursor: pointer;
  }
  .ag-td--cat {
    color: var(--ei-muted);
    white-space: nowrap;
  }
  .ag-td--desc {
    color: var(--ei-muted);
  }
  /* Long product descriptions clamp to 2 lines in the table; the full text is
     always in the DOM (SEO) and shown unclamped in the product detail modal. */
  .ag-clamp {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-wrap: pretty;
  }
  .ag-td--unit {
    color: var(--ei-muted);
    white-space: nowrap;
  }
  .ag-td--price {
    text-align: right;
    font-weight: 700;
    color: var(--ei-accent-text);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .ag-td--order {
    text-align: right;
    white-space: nowrap;
  }

  /* Thumbnail tile */
  .ag-thumb {
    width: 48px;
    height: 48px;
    border-radius: var(--ei-radius-md);
    object-fit: cover;
    display: block;
    border: 1px solid var(--ei-hairline);
    background: var(--ei-accent-soft);
  }
  .ag-thumb--ph {
    display: grid;
    place-items: center;
    border-color: transparent;
    background: var(--ei-accent-soft);
  }
  .ag-thumb--ph span {
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1;
    color: var(--ei-accent-text);
  }

  /* ---- Mobile: collapse each row into a stacked label/value card ------ */
  @media (max-width: 720px) {
    .ag-table-wrap {
      overflow-x: visible;
      border: 0;
      background: transparent;
      box-shadow: none;
      border-radius: 0;
    }
    .ag-table {
      min-width: 0;
    }
    .ag-table thead {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
    .ag-table,
    .ag-table tbody,
    .ag-row,
    .ag-td {
      display: block;
      width: auto;
    }
    .ag-row {
      position: relative;
      margin-bottom: 1rem;
      padding: 1rem 1.15rem 1.2rem;
      border: 1px solid var(--ei-hairline);
      border-radius: var(--ei-radius-lg);
      background: var(--ei-surface);
      box-shadow: var(--ei-shadow-sm);
    }
    .ag-row:hover {
      background: var(--ei-surface);
    }
    .ag-td {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      height: auto;
      padding: 0.4rem 0;
      text-align: right;
    }
    .ag-td[data-label]::before {
      content: attr(data-label);
      flex: 0 0 auto;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ei-faint);
      text-align: left;
    }
    .ag-td--cat,
    .ag-td--desc,
    .ag-td--unit,
    .ag-td--price {
      white-space: normal;
    }
    .ag-clamp {
      display: block;
      -webkit-line-clamp: unset;
    }
    /* Image tile is the card's leading element */
    .ag-td--img {
      justify-content: flex-start;
      padding-top: 0;
      padding-bottom: 0.7rem;
    }
    .ag-td--img::before {
      display: none;
    }
    .ag-td--name {
      padding-top: 0;
      padding-bottom: 0.7rem;
      margin-bottom: 0.2rem;
      border-bottom: 1px solid var(--ei-hairline);
    }
    .ag-td--name::before {
      display: none;
    }
    .ag-row__name {
      font-size: 1.05rem;
    }
    .ag-td--order {
      display: block;
      padding-top: 0.9rem;
      text-align: left;
    }
    .ag-td--order .ag-row__order {
      display: flex;
      width: 100%;
    }
  }

  /* ---- Order chooser sheet -------------------------------------------- */
  .ag-sheet {
    position: fixed;
    inset: 0;
    z-index: 2147483000;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  .ag-sheet[hidden] {
    display: none;
  }
  .ag-sheet__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(8, 20, 22, 0.55);
    opacity: 0;
    transition: opacity 0.25s var(--ei-ease);
  }
  .ag-sheet.is-open .ag-sheet__backdrop {
    opacity: 1;
  }
  .ag-sheet__panel {
    position: relative;
    width: 100%;
    max-width: 520px;
    margin: 0 0.75rem 0.75rem;
    padding: 1.6rem 1.5rem 1.8rem;
    background: var(--ei-surface);
    border: 1px solid var(--ei-hairline-strong);
    border-radius: var(--ei-radius-lg);
    box-shadow: var(--ei-shadow-lg);
    transform: translateY(16px);
    opacity: 0;
    transition: transform 0.28s var(--ei-ease-out), opacity 0.2s var(--ei-ease);
  }
  .ag-sheet.is-open .ag-sheet__panel {
    transform: translateY(0);
    opacity: 1;
  }
  .ag-sheet__panel h2 {
    font-size: 1.25rem;
    padding-right: 2rem;
  }
  .ag-sheet__body {
    margin-top: 0.5rem;
    color: var(--ei-muted);
    font-size: 0.94rem;
  }
  .ag-sheet__product {
    margin-top: 0.9rem;
    padding: 0.6rem 0.9rem;
    background: var(--ei-accent-soft);
    border-radius: var(--ei-radius-sm);
    color: var(--ei-accent-strong);
    font-weight: 600;
    font-size: 0.92rem;
  }
  .ag-sheet__product:empty {
    display: none;
  }
  .ag-sheet__actions {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 1.3rem;
  }
  .ag-sheet__actions .ag-btn {
    width: 100%;
  }
  .ag-sheet__close {
    position: absolute;
    top: 0.9rem;
    right: 0.9rem;
    display: inline-flex;
    padding: 0.4rem;
    border: none;
    background: transparent;
    color: var(--ei-muted);
    cursor: pointer;
    border-radius: var(--ei-radius-xs);
  }
  .ag-sheet__close:hover {
    color: var(--ei-ink);
  }

  @media (min-width: 640px) {
    .ag-sheet {
      align-items: center;
    }
    .ag-sheet__panel {
      margin-bottom: 0;
      transform: translateY(0) scale(0.96);
    }
    .ag-sheet.is-open .ag-sheet__panel {
      transform: translateY(0) scale(1);
    }
    .ag-sheet__actions {
      flex-direction: row;
    }
  }

  /* ---- Product detail modal ------------------------------------------ */
  .ag-modal {
    position: fixed;
    inset: 0;
    z-index: 2147483000;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  .ag-modal[hidden] {
    display: none;
  }
  .ag-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(8, 20, 22, 0.55);
    opacity: 0;
    transition: opacity 0.25s var(--ei-ease);
  }
  .ag-modal.is-open .ag-modal__backdrop {
    opacity: 1;
  }
  .ag-modal__panel {
    position: relative;
    width: 100%;
    max-width: 560px;
    margin: 0 0.75rem 0.75rem;
    padding: 1.7rem 1.5rem 1.8rem;
    background: var(--ei-surface);
    border: 1px solid var(--ei-hairline-strong);
    border-radius: var(--ei-radius-lg);
    box-shadow: var(--ei-shadow-lg);
    transform: translateY(16px);
    opacity: 0;
    transition: transform 0.28s var(--ei-ease-out), opacity 0.2s var(--ei-ease);
    max-height: 88vh;
    overflow-y: auto;
  }
  .ag-modal.is-open .ag-modal__panel {
    transform: translateY(0);
    opacity: 1;
  }
  .ag-modal__eyebrow {
    margin: 0;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--ei-faint);
  }
  .ag-modal__name {
    margin: 0.35rem 0 0;
    font-size: 1.3rem;
    padding-right: 2rem;
    color: var(--ei-ink);
  }
  .ag-modal__meta {
    display: grid;
    gap: 0.5rem 1rem;
    margin: 1.1rem 0 0;
  }
  .ag-modal__row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--ei-hairline);
  }
  .ag-modal__row[hidden] {
    display: none;
  }
  .ag-modal__row dt {
    flex: 0 0 auto;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ei-faint);
  }
  .ag-modal__row dd {
    margin: 0;
    text-align: right;
    color: var(--ei-ink-soft);
    font-weight: 600;
  }
  .ag-modal__row [data-modal-sku] {
    font-family: var(--ei-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
    font-size: 0.85rem;
  }
  .ag-modal__desc {
    margin: 1.1rem 0 0;
    color: var(--ei-muted);
    font-size: 0.95rem;
    line-height: 1.55;
    text-wrap: pretty;
  }
  .ag-modal__desc:empty {
    display: none;
  }
  .ag-modal__actions {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 1.4rem;
  }
  .ag-modal__actions .ag-btn {
    width: 100%;
  }
  .ag-modal__close {
    position: absolute;
    top: 0.9rem;
    right: 0.9rem;
    display: inline-flex;
    padding: 0.4rem;
    border: none;
    background: transparent;
    color: var(--ei-muted);
    cursor: pointer;
    border-radius: var(--ei-radius-xs);
  }
  .ag-modal__close:hover {
    color: var(--ei-ink);
  }
  @media (min-width: 640px) {
    .ag-modal {
      align-items: center;
    }
    .ag-modal__panel {
      margin-bottom: 0;
      transform: translateY(0) scale(0.96);
    }
    .ag-modal.is-open .ag-modal__panel {
      transform: translateY(0) scale(1);
    }
    .ag-modal__actions {
      flex-direction: row-reverse;
      justify-content: flex-start;
    }
    .ag-modal__actions .ag-btn {
      width: auto;
    }
  }

  /* ---- Search box + select hint -------------------------------------- */
  .ag-catalog__toolbar--search {
    align-items: center;
  }
  .ag-search {
    position: relative;
    flex: 1 1 260px;
    max-width: 440px;
  }
  .ag-search__icon {
    position: absolute;
    left: 0.9rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--ei-faint);
    pointer-events: none;
  }
  .ag-search__input {
    width: 100%;
    padding: 0.6rem 0.9rem 0.6rem 2.6rem;
    font: inherit;
    font-size: 0.92rem;
    color: var(--ei-ink);
    background: var(--ei-surface);
    border: 1px solid var(--ei-hairline-strong);
    border-radius: var(--ei-radius-pill);
    transition: border-color 0.2s var(--ei-ease), box-shadow 0.2s var(--ei-ease);
  }
  .ag-search__input::placeholder {
    color: var(--ei-faint);
  }
  .ag-search__input:focus-visible {
    outline: none;
    border-color: var(--ei-accent);
    box-shadow: 0 0 0 3px var(--ei-accent-soft);
  }
  .ag-catalog__hint {
    margin: 0 0 1.1rem;
    color: var(--ei-faint);
    font-size: 0.82rem;
  }

  /* ---- Select checkbox column ---------------------------------------- */
  .ag-th--check,
  .ag-td--check {
    width: 44px;
    text-align: center;
    white-space: nowrap;
  }
  .ag-check {
    width: 18px;
    height: 18px;
    margin: 0;
    accent-color: var(--ei-accent);
    cursor: pointer;
    vertical-align: middle;
  }
  .ag-row:has(.ag-check:checked) {
    background: var(--ei-accent-soft);
  }

  /* ---- Selection action bar (sticky bottom) -------------------------- */
  .ag-selbar {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2147482000;
    padding: 0.8rem 0;
    background: var(--ei-surface-contrast);
    border-top: 1px solid var(--ei-hairline-strong);
    box-shadow: var(--ei-shadow-lg);
    animation: ag-selbar-in 0.24s var(--ei-ease-out);
  }
  .ag-selbar[hidden] {
    display: none;
  }
  @keyframes ag-selbar-in {
    from { transform: translateY(100%); }
    to { transform: translateY(0); }
  }
  .ag-selbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .ag-selbar__count {
    color: var(--ei-on-contrast);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }
  .ag-selbar__actions {
    display: flex;
    gap: 0.6rem;
    flex: 0 0 auto;
  }
  .ag-selbar__actions .ag-btn--secondary {
    color: var(--ei-on-contrast);
    border-color: rgba(255, 255, 255, 0.28);
    background: transparent;
  }
  .ag-selbar__actions .ag-btn--secondary:hover {
    border-color: rgba(255, 255, 255, 0.6);
    background: rgba(255, 255, 255, 0.08);
    color: var(--ei-on-contrast);
  }

  /* Mobile: float the checkbox into the card's top-right corner. */
  @media (max-width: 720px) {
    .ag-row {
      padding-right: 3.1rem;
    }
    .ag-td--check {
      position: absolute;
      top: 0.9rem;
      right: 0.9rem;
      width: auto;
      padding: 0;
    }
    .ag-td--check::before {
      display: none;
    }
    .ag-selbar {
      padding: 0.7rem 0;
    }
    .ag-selbar__inner {
      justify-content: center;
    }
    .ag-selbar__actions {
      flex: 1 1 auto;
    }
    .ag-selbar__actions .ag-btn {
      flex: 1;
    }
  }
</style>
