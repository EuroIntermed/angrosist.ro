---
/**
 * CategoryProducts — a single category's page (/produse/[slug]).
 *
 * Renders the category hero (image + name + count), then that category's product
 * TABLE. Rows are server-rendered at build time from the joined catalog data
 * (SEO + no-JS), and src/scripts/catalog.ts refreshes them from the live sheet at
 * runtime in single-category mode (cfg.category) — no filter chips. Each row's
 * "Comandă" runs the device-aware widget/WhatsApp flow (src/scripts/order.ts).
 */
import type { Locale } from '../i18n/ui'
import { t } from '../i18n/utils'
import { localizePath } from '../i18n/utils'
import { waLink, productsUrl, whatsappNumber } from '../lib/config'
import type { CategoryWithProducts } from '../lib/catalog-data'
import BaseLayout from './BaseLayout.astro'
import CatalogTableStyles from './CatalogTableStyles.astro'

interface Props {
  locale: Locale
  category: CategoryWithProducts
}
const { locale, category } = Astro.props as Props
const c = t(locale)
const cat = c.catalog
const rows = category.products

const title = cat.categoryMetaTitle.replace('{category}', category.categorie)
const description = cat.categoryMetaDescription
  .replace('{category}', category.categorie)
  .replace('{count}', String(category.count))
const intro = cat.categoryIntro.replace('{category}', category.categorie)
const produseHref = localizePath('/produse', locale)

// No-JS wa.me fallback — includes ALL the product info we have.
const orderMessage = (p: { produs: string; categorie: string; unitate: string; descriere: string }) =>
  c.order.message
    .replace('{product}', p.produs)
    .replace('{category}', p.categorie || '—')
    .replace('{unit}', p.unitate || '—')
    .replace('{details}', p.descriere || '—')

// Client config — single-category mode (no chips; only this category's rows).
const catalogConfig = {
  productsUrl,
  waNumber: whatsappNumber,
  intent: 'buy',
  category: category.categorie,
  orderTemplate: c.order.message,
  orderMultiIntro: c.order.messageMultiIntro,
  orderMultiItem: c.order.messageMultiItem,
  orderMultiOutro: c.order.messageMultiOutro,
  strings: {
    filterAll: cat.filterAll,
    loading: cat.loading,
    empty: cat.empty,
    error: cat.error,
    retry: cat.retry,
    sampleNote: cat.sampleNote,
    orderCta: cat.orderCta,
    imageAlt: cat.imageAlt,
    headImage: cat.headImage,
    headProduct: cat.headProduct,
    headCategory: cat.headCategory,
    headDesc: cat.headDesc,
    headUnit: cat.headUnit,
    headOrder: cat.headOrder,
    headSelect: cat.headSelect,
    priceEmpty: cat.priceEmpty,
    results: cat.results,
    searchPlaceholder: cat.searchPlaceholder,
    searchEmpty: cat.searchEmpty,
    selectAll: cat.selectAll,
    selectedCount: cat.selectedCount,
    orderSelected: cat.orderSelected,
    clearSelection: cat.clearSelection,
  },
}

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: title,
  itemListElement: rows.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: p.produs,
      category: category.categorie,
      description: p.descriere,
      ...(p.imagine ? { image: p.imagine } : {}),
    },
  })),
}
const hasHero = /^https?:\/\//i.test(category.imagine)
---

<BaseLayout locale={locale} title={title} description={description} breadcrumb={category.categorie}>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListJsonLd)} />
  </Fragment>

  <section class="ag-catalog">
    <div class="ei-container">
      <a class="ag-cat-back" href={produseHref}>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6" /></svg>
        {cat.backToCategories}
      </a>

      <header class="ag-cat-hero" data-reveal>
        <div class="ag-cat-hero__text">
          <p class="ei-eyebrow">{cat.eyebrow}</p>
          <h1>{category.categorie}</h1>
          <p class="ei-lead">{intro}</p>
          <p class="ag-cat-hero__count"><strong>{category.count}</strong> {cat.results}</p>
        </div>
        {hasHero && (
          <div class="ag-cat-hero__media">
            <img src={category.imagine} alt={category.categorie} loading="eager" decoding="async" width="640" height="420" />
          </div>
        )}
      </header>

      <div data-catalog-root>
        <div class="ag-catalog__toolbar ag-catalog__toolbar--search">
          <div class="ag-search">
            <svg class="ag-search__icon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" /></svg>
            <input type="search" class="ag-search__input" data-catalog-search placeholder={cat.searchPlaceholder} aria-label={cat.searchPlaceholder} autocomplete="off" />
          </div>
          <p class="ag-catalog__count" data-catalog-count aria-live="polite">{rows.length} {cat.results}</p>
        </div>
        <p class="ag-catalog__hint">{cat.selectHint}</p>

        <div class="ag-catalog__status" data-catalog-status hidden></div>

        <div class="ag-table-wrap" data-catalog-table-wrap>
          <table class="ag-table ag-table--select">
            <thead>
              <tr>
                <th scope="col" class="ag-th ag-th--check"><input type="checkbox" class="ag-check" data-catalog-selectall aria-label={cat.selectAll} /></th>
                <th scope="col" class="ag-th ag-th--img">{cat.headImage}</th>
                <th scope="col" class="ag-th ag-th--name">{cat.headProduct}</th>
                <th scope="col" class="ag-th ag-th--desc">{cat.headDesc}</th>
                <th scope="col" class="ag-th ag-th--unit">{cat.headUnit}</th>
                <th scope="col" class="ag-th ag-th--order"><span class="ei-sr-only">{cat.headOrder}</span></th>
              </tr>
            </thead>
            <tbody data-catalog-tbody>
              {
                rows.map((p) => (
                  <tr class="ag-row" data-category={p.categorie || '—'}>
                    <td class="ag-td ag-td--check" data-label={cat.headSelect}>
                      <input type="checkbox" class="ag-check" aria-label={`${cat.headSelect}: ${p.produs}`} />
                    </td>
                    <td class="ag-td ag-td--img" data-label={cat.headImage}>
                      {/^https?:\/\//i.test(p.imagine) ? (
                        <img class="ag-thumb" src={p.imagine} alt={p.produs} loading="lazy" decoding="async" width="48" height="48" />
                      ) : (
                        <div class="ag-thumb ag-thumb--ph" aria-hidden="true"><span>{(p.produs.trim()[0] || '·').toUpperCase()}</span></div>
                      )}
                    </td>
                    <td class="ag-td ag-td--name" data-label={cat.headProduct}><span class="ag-row__name">{p.produs}</span></td>
                    <td class="ag-td ag-td--desc" data-label={cat.headDesc}><span class="ag-clamp">{p.descriere}</span></td>
                    <td class="ag-td ag-td--unit" data-label={cat.headUnit}>{p.unitate || cat.priceEmpty}</td>
                    <td class="ag-td ag-td--order">
                      <a
                        class="ag-btn ag-btn--primary ag-row__order"
                        href={waLink(orderMessage(p))}
                        target="_blank"
                        rel="noopener"
                        data-ga-vertical="whatsapp"
                      >
                        {cat.orderCta}
                      </a>
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Selection action bar — slides up when products are ticked (catalog.ts) -->
  <div class="ag-selbar" data-catalog-selbar role="region" aria-label={cat.orderSelected} hidden>
    <div class="ei-container ag-selbar__inner">
      <span class="ag-selbar__count" data-sel-count>{cat.selectedCount.replace('{n}', '0')}</span>
      <div class="ag-selbar__actions">
        <button type="button" class="ag-btn ag-btn--secondary" data-sel-clear>{cat.clearSelection}</button>
        <button type="button" class="ag-btn ag-btn--primary" data-sel-order>{cat.orderSelected}</button>
      </div>
    </div>
  </div>

  <!-- Mobile order chooser (accessible dialog; controlled by order.ts) -->
  <div class="ag-sheet" data-order-sheet role="dialog" aria-modal="true" aria-labelledby="ag-sheet-title" aria-describedby="ag-sheet-body" hidden>
    <div class="ag-sheet__backdrop" data-order-close></div>
    <div class="ag-sheet__panel">
      <button type="button" class="ag-sheet__close" data-order-close aria-label={c.order.close}>
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12" /></svg>
      </button>
      <h2 id="ag-sheet-title">{c.order.sheetTitle}</h2>
      <p id="ag-sheet-body" class="ag-sheet__body">{c.order.sheetBody}</p>
      <p class="ag-sheet__product" data-order-product></p>
      <div class="ag-sheet__actions">
        <button type="button" class="ag-btn ag-btn--whatsapp" data-order-whatsapp>{c.order.whatsapp}</button>
        <button type="button" class="ag-btn ag-btn--secondary" data-order-widget>{c.order.widget}</button>
      </div>
    </div>
  </div>

  <script type="application/json" data-catalog-config is:inline set:html={JSON.stringify(catalogConfig)} />
  <script type="application/json" data-catalog-fallback is:inline set:html={JSON.stringify(rows)} />
  <script>
    import '../scripts/catalog.ts'
  </script>

  <CatalogTableStyles />
</BaseLayout>

<style>
  .ag-catalog {
    padding-block: clamp(2.5rem, 2rem + 4vw, 5rem);
  }
  .ag-cat-back {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-bottom: 1.5rem;
    color: var(--ei-muted);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s var(--ei-ease);
  }
  .ag-cat-back:hover {
    color: var(--ei-accent-strong);
  }
  .ag-cat-hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem 2.5rem;
    align-items: center;
    margin-bottom: 2.2rem;
  }
  .ag-cat-hero__text {
    max-width: 60ch;
  }
  .ag-cat-hero__text h1 {
    margin-top: 0.7rem;
  }
  .ag-cat-hero__text .ei-lead {
    margin-top: 0.9rem;
  }
  .ag-cat-hero__count {
    margin-top: 1.1rem;
    color: var(--ei-faint);
    font-size: 0.95rem;
    font-variant-numeric: tabular-nums;
  }
  .ag-cat-hero__count strong {
    color: var(--ei-accent-strong);
    font-size: 1.15rem;
  }
  .ag-cat-hero__media {
    border-radius: var(--ei-radius-lg);
    overflow: hidden;
    border: 1px solid var(--ei-hairline);
    box-shadow: var(--ei-shadow-md);
    aspect-ratio: 16 / 10;
    background: var(--ei-accent-soft);
  }
  .ag-cat-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  @media (min-width: 860px) {
    .ag-cat-hero {
      grid-template-columns: 1.15fr 0.85fr;
    }
  }
  .ag-catalog__toolbar--solo {
    justify-content: flex-end;
  }
</style>
