---
/**
 * Catalog — the "Produse" page. A prerendered shell (intro, category chips and a
 * sample product TABLE for SEO + no-JS) that the client runtime
 * (src/scripts/catalog.ts) upgrades: it fetches the live sheet from
 * PUBLIC_PRODUCTS_URL, groups by category, rebuilds the table body, and wires each
 * "Comandă" button into the device-aware order flow.
 *
 * Progressive enhancement: without JS, each sample row's "Comandă" is a real
 * wa.me link; with JS the button becomes the device-aware widget/WhatsApp chooser.
 * SEO: page shell + category names + a JSON-LD ItemList are emitted at build time.
 *
 * Layout: a clean data-table styled through the shared design tokens (teal theme),
 * wrapped in an overflow-x container so the page never scrolls sideways; on phones
 * each row collapses into a stacked "label: value" card (CSS, data-label driven).
 *
 * STYLING NOTE: this component's <style> is `is:global` on purpose — the runtime
 * renderer builds rows in plain JS (they carry no Astro scope hash), so the table,
 * thumbnail and button classes must be global to apply to both SSR and runtime DOM.
 * All classes are `ag-`-prefixed to avoid collisions.
 */
import type { Locale } from '../i18n/ui'
import { t } from '../i18n/utils'
import { waLink, productsUrl, whatsappNumber } from '../lib/config'
import { groupByCategory, sampleProducts } from '../lib/products'
import BaseLayout from './BaseLayout.astro'

const { locale } = Astro.props as { locale: Locale }
const c = t(locale)
const cat = c.catalog

// Build-time skeleton + SEO content from the bundled sample.
const groups = groupByCategory(sampleProducts)
const sampleCount = groups.reduce((n, g) => n + g.items.length, 0)

// Prefilled order message for the no-JS wa.me fallback on each sample row.
const orderMessage = (produs: string, categorie: string) =>
  c.order.message.replace('{product}', produs).replace('{category}', categorie || '—')

// Client config (no secrets — all public). productsUrl is env-injected at build.
const catalogConfig = {
  productsUrl,
  waNumber: whatsappNumber,
  intent: 'buy',
  orderTemplate: c.order.message,
  strings: {
    filterAll: cat.filterAll,
    loading: cat.loading,
    empty: cat.empty,
    error: cat.error,
    retry: cat.retry,
    sampleNote: cat.sampleNote,
    orderCta: cat.orderCta,
    priceLabel: cat.priceLabel,
    imageAlt: cat.imageAlt,
    headImage: cat.headImage,
    headProduct: cat.headProduct,
    headCategory: cat.headCategory,
    headDesc: cat.headDesc,
    headUnit: cat.headUnit,
    headPrice: cat.headPrice,
    headOrder: cat.headOrder,
    priceEmpty: cat.priceEmpty,
    results: cat.results,
  },
}

// JSON-LD ItemList (representative — from the sample catalog).
const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: c.meta.produseTitle,
  itemListElement: sampleProducts
    .filter((p) => p.activ)
    .map((p, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'Product',
        name: p.produs,
        category: p.categorie,
        description: p.descriere,
        ...(p.imagine ? { image: p.imagine } : {}),
      },
    })),
}
const showSampleNote = !productsUrl

// Flatten the sample groups into ordered rows for the SSR table body.
const sampleRows = groups.flatMap((g) => g.items)
---

<BaseLayout locale={locale} title={c.meta.produseTitle} description={c.meta.produseDescription}>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListJsonLd)} />
  </Fragment>

  <section class="ag-catalog">
    <div class="ei-container">
      <div class="ag-catalog__head" data-reveal>
        <p class="ei-eyebrow">{cat.eyebrow}</p>
        <h1>{cat.title}</h1>
        <p class="ei-lead">{cat.lead}</p>
      </div>

      <div data-catalog-root>
        <p class="ag-catalog__note" data-catalog-note hidden={!showSampleNote}>{cat.sampleNote}</p>

        <div class="ag-catalog__toolbar">
          <div class="ag-catalog__filters" role="tablist" aria-label={cat.filterLabel} data-catalog-filters>
            <button type="button" class="ag-chip is-active" role="tab" aria-selected="true">{cat.filterAll}</button>
            {groups.map((g) => (
              <button type="button" class="ag-chip" role="tab" aria-selected="false">{g.categorie}</button>
            ))}
          </div>
          <p class="ag-catalog__count" data-catalog-count aria-live="polite">{sampleCount} {cat.results}</p>
        </div>

        <div class="ag-catalog__status" data-catalog-status hidden></div>

        <div class="ag-table-wrap" data-catalog-table-wrap>
          <table class="ag-table">
            <thead>
              <tr>
                <th scope="col" class="ag-th ag-th--img">{cat.headImage}</th>
                <th scope="col" class="ag-th ag-th--name">{cat.headProduct}</th>
                <th scope="col" class="ag-th ag-th--cat">{cat.headCategory}</th>
                <th scope="col" class="ag-th ag-th--desc">{cat.headDesc}</th>
                <th scope="col" class="ag-th ag-th--unit">{cat.headUnit}</th>
                <th scope="col" class="ag-th ag-th--price">{cat.headPrice}</th>
                <th scope="col" class="ag-th ag-th--order"><span class="ei-sr-only">{cat.headOrder}</span></th>
              </tr>
            </thead>
            <tbody data-catalog-tbody>
              {
                sampleRows.map((p) => (
                  <tr class="ag-row" data-category={p.categorie || '—'}>
                    <td class="ag-td ag-td--img" data-label={cat.headImage}>
                      {/^https?:\/\//i.test(p.imagine) ? (
                        <img class="ag-thumb" src={p.imagine} alt={p.produs} loading="lazy" decoding="async" width="48" height="48" />
                      ) : (
                        <div class="ag-thumb ag-thumb--ph" aria-hidden="true"><span>{(p.produs.trim()[0] || '·').toUpperCase()}</span></div>
                      )}
                    </td>
                    <td class="ag-td ag-td--name" data-label={cat.headProduct}><span class="ag-row__name">{p.produs}</span></td>
                    <td class="ag-td ag-td--cat" data-label={cat.headCategory}>{p.categorie || '—'}</td>
                    <td class="ag-td ag-td--desc" data-label={cat.headDesc}><span class="ag-clamp">{p.descriere}</span></td>
                    <td class="ag-td ag-td--unit" data-label={cat.headUnit}>{p.unitate || cat.priceEmpty}</td>
                    <td class="ag-td ag-td--price" data-label={cat.headPrice} title={p.pret ? cat.priceLabel : undefined}>{p.pret || cat.priceEmpty}</td>
                    <td class="ag-td ag-td--order">
                      <a
                        class="ag-btn ag-btn--primary ag-row__order"
                        href={waLink(orderMessage(p.produs, p.categorie))}
                        target="_blank"
                        rel="noopener"
                        data-ga-vertical="whatsapp"
                      >
                        {cat.orderCta}
                      </a>
                    </td>
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Mobile order chooser (accessible dialog; controlled by order.ts) -->
  <div class="ag-sheet" data-order-sheet role="dialog" aria-modal="true" aria-labelledby="ag-sheet-title" aria-describedby="ag-sheet-body" hidden>
    <div class="ag-sheet__backdrop" data-order-close></div>
    <div class="ag-sheet__panel">
      <button type="button" class="ag-sheet__close" data-order-close aria-label={c.order.close}>
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12" /></svg>
      </button>
      <h2 id="ag-sheet-title">{c.order.sheetTitle}</h2>
      <p id="ag-sheet-body" class="ag-sheet__body">{c.order.sheetBody}</p>
      <p class="ag-sheet__product" data-order-product></p>
      <div class="ag-sheet__actions">
        <button type="button" class="ag-btn ag-btn--whatsapp" data-order-whatsapp>{c.order.whatsapp}</button>
        <button type="button" class="ag-btn ag-btn--secondary" data-order-widget>{c.order.widget}</button>
      </div>
    </div>
  </div>

  <script type="application/json" data-catalog-config is:inline set:html={JSON.stringify(catalogConfig)} />
  <script type="application/json" data-catalog-fallback is:inline set:html={JSON.stringify(sampleProducts)} />
  <script>
    import '../scripts/catalog.ts'
  </script>
</BaseLayout>

<style is:global>
  .ag-catalog {
    padding-block: clamp(2.5rem, 2rem + 4vw, 5rem);
  }
  .ag-catalog__head {
    max-width: 62ch;
    margin-bottom: 2rem;
  }
  .ag-catalog__head h1 {
    margin-top: 0.7rem;
  }
  .ag-catalog__head .ei-lead {
    margin-top: 1rem;
  }
  .ag-catalog__note {
    margin: 0 0 1.5rem;
    padding: 0.7rem 1rem;
    border: 1px dashed var(--ei-gold-strong);
    border-radius: var(--ei-radius-sm);
    background: var(--ei-gold-soft);
    color: var(--ei-ink-soft);
    font-size: 0.86rem;
  }

  /* Toolbar: filter chips + result count */
  .ag-catalog__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem 1.5rem;
    margin-bottom: 1.4rem;
  }
  .ag-catalog__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }
  .ag-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.5em 1em;
    border: 1px solid var(--ei-hairline-strong);
    border-radius: var(--ei-radius-pill);
    background: var(--ei-surface);
    color: var(--ei-ink-soft);
    font-family: inherit;
    font-size: 0.88rem;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.2s var(--ei-ease), background 0.2s var(--ei-ease), color 0.2s var(--ei-ease), transform 0.15s var(--ei-ease-out);
  }
  .ag-chip:hover {
    border-color: var(--ei-accent);
    transform: translateY(-1px);
  }
  .ag-chip.is-active {
    background: var(--ei-accent-soft);
    border-color: var(--ei-accent);
    color: var(--ei-accent-strong);
    font-weight: 600;
  }
  .ag-catalog__count {
    font-size: 0.84rem;
    font-weight: 600;
    color: var(--ei-faint);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .ag-catalog__count[hidden] {
    display: none;
  }

  /* Status (loading / empty / error) */
  .ag-catalog__status {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    padding: 2.5rem 0;
    color: var(--ei-muted);
  }
  .ag-catalog__status[hidden] {
    display: none;
  }
  .ag-catalog__status.is-loading {
    color: var(--ei-faint);
  }
  .ag-catalog__status.is-error p {
    color: var(--ei-ink-soft);
  }

  /* ---- Self-contained button system (works for SSR + runtime DOM) ----- */
  .ag-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5em;
    padding: 0.6em 1.2em;
    border: 1px solid transparent;
    border-radius: var(--ei-radius-pill);
    font-family: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: -0.01em;
    cursor: pointer;
    text-align: center;
    transition: transform 0.2s var(--ei-ease-out), box-shadow 0.25s var(--ei-ease),
      background-color 0.2s var(--ei-ease), border-color 0.2s var(--ei-ease), color 0.2s var(--ei-ease);
  }
  .ag-btn:hover {
    transform: translateY(-1px);
    box-shadow: var(--ei-shadow-md);
  }
  .ag-btn:active {
    transform: translateY(0);
  }
  .ag-btn--primary {
    background: var(--ei-accent);
    color: var(--ei-accent-ink);
    box-shadow: var(--ei-shadow-sm);
  }
  .ag-btn--primary:hover {
    background: var(--ei-accent-hover);
    box-shadow: var(--ei-shadow-md);
  }
  .ag-btn--secondary {
    background: transparent;
    color: var(--ei-accent-text);
    border-color: var(--ei-hairline-strong);
  }
  .ag-btn--secondary:hover {
    background: var(--ei-accent-soft);
    border-color: var(--ei-accent);
    color: var(--ei-accent-strong);
  }
  .ag-btn--whatsapp {
    background: var(--ei-whatsapp);
    color: var(--ei-whatsapp-ink);
  }
  .ag-btn--whatsapp:hover {
    filter: brightness(0.96);
  }
  .ag-row__order {
    padding: 0.55em 1.15em;
    font-size: 0.85rem;
    white-space: nowrap;
  }

  /* ---- Table ---------------------------------------------------------- */
  .ag-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--ei-hairline);
    border-radius: var(--ei-radius-lg);
    background: var(--ei-surface);
    box-shadow: var(--ei-shadow-sm);
    -webkit-overflow-scrolling: touch;
  }
  .ag-table-wrap[hidden] {
    display: none;
  }
  .ag-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.94rem;
    min-width: 760px;
  }
  .ag-th {
    text-align: left;
    padding: 0.85rem 1.1rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--ei-faint);
    background: var(--ei-surface-raised);
    border-bottom: 1px solid var(--ei-hairline-strong);
    white-space: nowrap;
  }
  .ag-th--img {
    width: 64px;
  }
  .ag-th--desc {
    width: 38%;
  }
  .ag-th--price {
    text-align: right;
  }
  .ag-th--order {
    width: 1%;
  }

  .ag-row {
    border-bottom: 1px solid var(--ei-hairline);
    transition: background 0.15s var(--ei-ease);
  }
  .ag-row:last-child {
    border-bottom: 0;
  }
  .ag-row:hover {
    background: var(--ei-accent-soft);
  }
  .ag-row[hidden] {
    display: none;
  }
  .ag-td {
    height: 64px;
    padding: 0.7rem 1.1rem;
    vertical-align: middle;
    color: var(--ei-ink-soft);
  }
  .ag-td--img {
    width: 64px;
  }
  .ag-row__name {
    font-weight: 600;
    color: var(--ei-ink);
  }
  .ag-td--cat {
    color: var(--ei-muted);
    white-space: nowrap;
  }
  .ag-td--desc {
    color: var(--ei-muted);
  }
  .ag-clamp {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-wrap: pretty;
  }
  .ag-td--unit {
    color: var(--ei-muted);
    white-space: nowrap;
  }
  .ag-td--price {
    text-align: right;
    font-weight: 700;
    color: var(--ei-accent-text);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .ag-td--order {
    text-align: right;
    white-space: nowrap;
  }

  /* Thumbnail tile */
  .ag-thumb {
    width: 48px;
    height: 48px;
    border-radius: var(--ei-radius-md);
    object-fit: cover;
    display: block;
    border: 1px solid var(--ei-hairline);
    background: var(--ei-accent-soft);
  }
  .ag-thumb--ph {
    display: grid;
    place-items: center;
    border-color: transparent;
    background: var(--ei-accent-soft);
  }
  .ag-thumb--ph span {
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1;
    color: var(--ei-accent-text);
  }

  /* ---- Mobile: collapse each row into a stacked label/value card ------ */
  @media (max-width: 720px) {
    .ag-table-wrap {
      overflow-x: visible;
      border: 0;
      background: transparent;
      box-shadow: none;
      border-radius: 0;
    }
    .ag-table {
      min-width: 0;
    }
    .ag-table thead {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
    .ag-table,
    .ag-table tbody,
    .ag-row,
    .ag-td {
      display: block;
      width: auto;
    }
    .ag-row {
      position: relative;
      margin-bottom: 1rem;
      padding: 1rem 1.15rem 1.2rem;
      border: 1px solid var(--ei-hairline);
      border-radius: var(--ei-radius-lg);
      background: var(--ei-surface);
      box-shadow: var(--ei-shadow-sm);
    }
    .ag-row:hover {
      background: var(--ei-surface);
    }
    .ag-td {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
      height: auto;
      padding: 0.4rem 0;
      text-align: right;
    }
    .ag-td[data-label]::before {
      content: attr(data-label);
      flex: 0 0 auto;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ei-faint);
      text-align: left;
    }
    .ag-td--cat,
    .ag-td--desc,
    .ag-td--unit,
    .ag-td--price {
      white-space: normal;
    }
    .ag-clamp {
      display: block;
      -webkit-line-clamp: unset;
    }
    /* Image tile is the card's leading element */
    .ag-td--img {
      justify-content: flex-start;
      padding-top: 0;
      padding-bottom: 0.7rem;
    }
    .ag-td--img::before {
      display: none;
    }
    .ag-td--name {
      padding-top: 0;
      padding-bottom: 0.7rem;
      margin-bottom: 0.2rem;
      border-bottom: 1px solid var(--ei-hairline);
    }
    .ag-td--name::before {
      display: none;
    }
    .ag-row__name {
      font-size: 1.05rem;
    }
    .ag-td--order {
      display: block;
      padding-top: 0.9rem;
      text-align: left;
    }
    .ag-td--order .ag-row__order {
      display: flex;
      width: 100%;
    }
  }

  /* ---- Order chooser sheet -------------------------------------------- */
  .ag-sheet {
    position: fixed;
    inset: 0;
    z-index: 2147483000;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  .ag-sheet[hidden] {
    display: none;
  }
  .ag-sheet__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(8, 20, 22, 0.55);
    opacity: 0;
    transition: opacity 0.25s var(--ei-ease);
  }
  .ag-sheet.is-open .ag-sheet__backdrop {
    opacity: 1;
  }
  .ag-sheet__panel {
    position: relative;
    width: 100%;
    max-width: 520px;
    margin: 0 0.75rem 0.75rem;
    padding: 1.6rem 1.5rem 1.8rem;
    background: var(--ei-surface);
    border: 1px solid var(--ei-hairline-strong);
    border-radius: var(--ei-radius-lg);
    box-shadow: var(--ei-shadow-lg);
    transform: translateY(16px);
    opacity: 0;
    transition: transform 0.28s var(--ei-ease-out), opacity 0.2s var(--ei-ease);
  }
  .ag-sheet.is-open .ag-sheet__panel {
    transform: translateY(0);
    opacity: 1;
  }
  .ag-sheet__panel h2 {
    font-size: 1.25rem;
    padding-right: 2rem;
  }
  .ag-sheet__body {
    margin-top: 0.5rem;
    color: var(--ei-muted);
    font-size: 0.94rem;
  }
  .ag-sheet__product {
    margin-top: 0.9rem;
    padding: 0.6rem 0.9rem;
    background: var(--ei-accent-soft);
    border-radius: var(--ei-radius-sm);
    color: var(--ei-accent-strong);
    font-weight: 600;
    font-size: 0.92rem;
  }
  .ag-sheet__product:empty {
    display: none;
  }
  .ag-sheet__actions {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-top: 1.3rem;
  }
  .ag-sheet__actions .ag-btn {
    width: 100%;
  }
  .ag-sheet__close {
    position: absolute;
    top: 0.9rem;
    right: 0.9rem;
    display: inline-flex;
    padding: 0.4rem;
    border: none;
    background: transparent;
    color: var(--ei-muted);
    cursor: pointer;
    border-radius: var(--ei-radius-xs);
  }
  .ag-sheet__close:hover {
    color: var(--ei-ink);
  }

  @media (min-width: 640px) {
    .ag-sheet {
      align-items: center;
    }
    .ag-sheet__panel {
      margin-bottom: 0;
      transform: translateY(0) scale(0.96);
    }
    .ag-sheet.is-open .ag-sheet__panel {
      transform: translateY(0) scale(1);
    }
    .ag-sheet__actions {
      flex-direction: row;
    }
  }
</style>
